# Telegram
BOT_TOKEN=your_bot_token_here

# Environment
NODE_ENV=production

# Webhook
WEBHOOK_DOMAIN=https://your-bot-domain.com
WEBHOOK_PATH=/webhook

# Internal HTTP port (nginx reverse proxy handles SSL on 443)
PORT=3000

# Downloads
DOWNLOADS_DIR=/root/tg-gallery-downloads
DOWNLOAD_BASE_URL=https://your-bot-domain.com/downloads

# Whitelist (comma-separated user IDs, empty = everyone)
ALLOWED_USERS=

# Download concurrency (parallel image downloads per gallery)
DOWNLOAD_CONCURRENCY=5

# Proxy — pointing to Xray mixed inbound inside 3x-ui
# Create a 'mixed' inbound in 3x-ui panel:
#   Protocol : mixed
#   Listen IP: 127.0.0.1
#   Port     : 1080
#
# Without auth:
#   PROXY_URL=socks5://127.0.0.1:1080
#
# With username/password (if Password is enabled in 3x-ui):
#   PROXY_URL=socks5://USERNAME:PASSWORD@127.0.0.1:1080
PROXY_URL=socks5://USERNAME:PASSWORD@127.0.0.1:1080
